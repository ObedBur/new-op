{
  "name": "backend",
  "version": "1.0.0",
  "description": "NestJS backend application",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build --path tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start --path tsconfig.build.json",
    "start:dev": "nest start --watch --path tsconfig.build.json",
    "start:debug": "nest start --debug --watch --path tsconfig.build.json",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "dev": "nest start --watch --path tsconfig.build.json"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "@fastify/helmet": "^11.1.1",
    "@getbrevo/brevo": "^2.2.0",
    "@nestjs/common": "10.4.22",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "10.4.22",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-fastify": "10.4.22",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/config": "^7.5.0",
    "@tensorflow/tfjs": "^4.22.0",
    "axios": "^1.7.7",
    "bad-words": "^3.0.4",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "fastify": "4.28.1",
    "jimp": "^1.6.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.7",
    "nsfwjs": "^4.3.0",
    "openai": "^6.33.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "10.4.22",
    "@types/bad-words": "^3.0.3",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.11",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@types/passport-jwt": "^3.0.13",
    "@types/pg": "8.11.11",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "prisma": "^7.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
