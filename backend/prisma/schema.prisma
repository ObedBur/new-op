generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String         @id @default(uuid())
  email               String         @unique
  password            String
  fullName            String
  phone               String         @unique
  province            String
  commune             String
  address             String?
  role                UserRole       @default(CLIENT)
  boutiqueName        String?
  isVerified          Boolean        @default(false)
  otpHash             String?
  otpExpiresAt        DateTime?
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?
  kycStatus           KycStatus      @default(NOT_REQUIRED)
  kycSubmittedAt      DateTime?
  kycApprovedAt       DateTime?
  kycRejectedAt       DateTime?
  kycRejectionReason  String?
  trustScore          Int            @default(50)
  dailyPublications   Int            @default(0)
  lastPublicationDate DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  otpAttempts         Int            @default(0)
  city                String?
  country             String         @default("RD Congo")
  avatarUrl           String?
  coverUrl            String?
  isActive            Boolean        @default(true)
  products            Product[]
  refreshTokens       RefreshToken[]
  orders              Order[] @relation("ClientOrders")
  sales               Order[] @relation("VendorOrders")
  notifications       Notification[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([kycStatus])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Category {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  icon       String?
  colorClass String?
  bgClass    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  products   Product[]
}

model Product {
  id            String              @id @default(uuid())
  name          String
  description   String?
  price         Float
  originalPrice Float?
  isOnSale      Boolean             @default(false)
  totalSales    Int                 @default(0)
  displayPrice  String?
  location      String?
  image         String?
  availability  ProductAvailability @default(IN_STOCK)
  market        Market?
  categoryId    Int
  userId        String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  city          String              @default("Goma")
  country       String              @default("RD Congo")
  images        String[]            @default([])
  category      Category            @relation(fields: [categoryId], references: [id])
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]
  @@index([categoryId])
  @@index([userId])
  @@index([market])
  @@index([isOnSale])
  @@index([totalSales])
}

model HeroSlide {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  label     String?
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HowItWorksStep {
  id          String   @id @default(cuid())
  icon        String
  title       String
  description String
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Order {
  id              String      @id @default(uuid())
  
  // Informations saisies dans le modal (peuvent différer du profil User)
  customerName    String   
  customerPhone   String    
  customerEmail   String      
  deliveryAddress String      
  
  // Relations
  productId       String
  product         Product     @relation(fields: [productId], references: [id])
  
  clientId        String
  client          User        @relation("ClientOrders", fields: [clientId], references: [id])
  
  vendorId        String
  vendor          User        @relation("VendorOrders", fields: [vendorId], references: [id])

  // État de la commande
  status          OrderStatus @default(PENDING)
  totalPrice      Float
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([vendorId])
  @@index([clientId])
  @@index([status])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType @default(SYSTEM_ALERT)
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([userId])
}

enum OrderStatus {
  PENDING      
  CONFIRMED   
  SHIPPED    
  DELIVERED  
  CANCELLED   
}
enum UserRole {
  CLIENT
  VENDOR
  ADMIN
}

enum KycStatus {
  NOT_REQUIRED
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum ProductAvailability {
  IN_STOCK
  LIMITED_STOCK
  OUT_OF_STOCK
}

enum Market {
  VIRUNGA
  BIRERE
  CENTRE_VILLE
  HIMBI
  KATINDO
  KINSHASA
  LUBUMBASHI
  BUKAVU
  KISANGANI
  KIGALI
  NAIROBI
  KAMPALA
  DAR_ES_SALAAM
  AUTRE
}

enum NotificationType {
  ORDER_CREATED
  ORDER_CONFIRMED
  PAYMENT_RECEIVED
  SYSTEM_ALERT
}

