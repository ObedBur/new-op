# ===========================================
# WapiBei Frontend — Environment Variables
# ===========================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000/api

# Allowed origins for server actions (comma-separated)
# Example: localhost:3000,192.168.1.100:3000
ALLOWED_ORIGINS=localhost:3000

# Allowed dev origins for Next.js dev server (comma-separated)
# Example: 192.168.1.100,192.168.10.252
ALLOWED_DEV_ORIGINS=
