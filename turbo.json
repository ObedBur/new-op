{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [
                "dist/**",
                ".next/**",
                "!.next/cache/**"
            ]
        },
        "backend#build": {
            "dependsOn": ["backend#prisma:generate"]
        },
        "prisma:generate": {
            "cache": false,
            "inputs": ["prisma/schema.prisma"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["^lint"]
        }
    }
}
